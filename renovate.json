{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "schedule:earlyMondays"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "Group all Effect ecosystem packages together",
      "matchPackageNames": ["effect", "@effect/**"],
      "groupName": "effect ecosystem",
      "groupSlug": "effect",
      "automerge": false
    },
    {
      "description": "Group all Noble/Scure crypto packages together",
      "matchPackageNames": ["@noble/**", "@scure/**"],
      "groupName": "noble/scure crypto",
      "groupSlug": "noble-scure",
      "automerge": false
    },
    {
      "description": "Group ESLint + plugins together",
      "matchPackageNames": ["eslint", "@eslint/**", "eslint-*", "@typescript-eslint/**"],
      "groupName": "eslint",
      "groupSlug": "eslint",
      "automerge": true
    },
    {
      "description": "Group Babel packages together",
      "matchPackageNames": ["@babel/**", "babel-plugin-*"],
      "groupName": "babel",
      "groupSlug": "babel",
      "automerge": true
    },
    {
      "description": "Group Vitest + coverage together",
      "matchPackageNames": ["vitest", "@vitest/**"],
      "groupName": "vitest",
      "groupSlug": "vitest",
      "automerge": true
    },
    {
      "description": "Group Turbo packages together",
      "matchPackageNames": ["turbo", "@turbo/**"],
      "groupName": "turbo",
      "groupSlug": "turbo",
      "automerge": true
    },
    {
      "description": "Group TypeScript and @types packages",
      "matchPackageNames": ["typescript", "@types/**"],
      "groupName": "typescript",
      "groupSlug": "typescript",
      "automerge": true
    },
    {
      "description": "Group changesets packages",
      "matchPackageNames": ["@changesets/**"],
      "groupName": "changesets",
      "groupSlug": "changesets",
      "automerge": true
    },
    {
      "description": "Group Cardano ecosystem packages — review manually",
      "matchPackageNames": ["@dcspark/**", "@emurgo/**", "@cardano-foundation/**", "scalus"],
      "groupName": "cardano ecosystem",
      "groupSlug": "cardano",
      "automerge": false
    },
    {
      "description": "Group React ecosystem packages",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom", "@vitejs/plugin-react"],
      "groupName": "react",
      "groupSlug": "react",
      "automerge": true
    },
    {
      "description": "Group docs tooling (fumadocs, shiki, tailwind, etc.)",
      "matchPackageNames": ["fumadocs-*", "shiki", "@shikijs/**", "twoslash", "tailwindcss", "@tailwindcss/**", "postcss", "autoprefixer", "next-themes", "lucide-react", "mermaid", "@orama/**"],
      "groupName": "docs tooling",
      "groupSlug": "docs-tooling",
      "automerge": true
    },
    {
      "description": "Auto-merge all patch updates for devDependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Never auto-merge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "platformAutomerge": true
  },
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "platformAutomerge": true
}
